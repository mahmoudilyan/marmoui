# Marmo UI — design-system-docs environment example.
# Copy to `.env.local` and fill in real values. NEVER commit real secrets.

# ──────────────────────────────────────────────────────────────────────────
# Platform (Supabase) — licensing / entitlement spine
# ──────────────────────────────────────────────────────────────────────────
# When BOTH of these are set, getEntitlement() resolves the signed-in Supabase
# session and reads the account's entitlement; the webhook + MCP-token + resolve
# -tenant routes persist to / read from Supabase. When unset, the app falls back
# to the dev stubs below and all Platform writes no-op (local build/dev works).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public (browser-safe) Supabase auth credentials — enables magic-link sign-in
# (/signin, /welcome, /auth/confirm) and middleware session refresh. Same
# project as SUPABASE_URL above.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase dashboard setup for magic links:
#   Auth → Email templates → Magic Link: link to
#   {{ .SiteURL }}/auth/confirm?token_hash={{ .TokenHash }}&type=email&next=/welcome
#   Auth → URL configuration: Site URL = https://www.marmoui.com
# LemonSqueezy checkout success URL → https://www.marmoui.com/welcome

# ──────────────────────────────────────────────────────────────────────────
# Lemon Squeezy — checkout → entitlement webhook
# ──────────────────────────────────────────────────────────────────────────
# Signing secret configured on the webhook in the Lemon Squeezy dashboard.
# Used to verify the X-Signature HMAC on POST /api/webhooks/lemonsqueezy.
LEMONSQUEEZY_WEBHOOK_SECRET=
# Store + Pro variant identifiers (for building checkout links / reconciliation).
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID_PRO=

# Public URL of the hosted Marmo UI MCP server, shown in the /connect configs.
# Defaults to http://localhost:3001/mcp when unset.
NEXT_PUBLIC_MCP_URL=

# ──────────────────────────────────────────────────────────────────────────
# Sanity CMS — /updates posts + landing testimonials (see sanity/README.md)
# ──────────────────────────────────────────────────────────────────────────
# When unset, CMS-driven sections render nothing and the site builds fine.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Optional; defaults to 2026-07-01.
NEXT_PUBLIC_SANITY_API_VERSION=

# ──────────────────────────────────────────────────────────────────────────
# Dev stubs (used only when the Platform env vars above are absent)
# ──────────────────────────────────────────────────────────────────────────
# Treat every request as Pro (local dev / preview demos).
MARMO_DEV_PRO=
# Opaque value compared against the `marmo_session` cookie set by /api/unlock.
MARMO_DEV_SESSION=

# NOTE: also update `buyNowUrl` in apps/design-system-docs/site.config.ts to the
# Lemon Squeezy hosted checkout URL for the Pro variant (currently a TODO).

# ──────────────────────────────────────────────────────────────────────────
# MCP server (design-system-mcp) — set on the MCP container, not the docs app
# ──────────────────────────────────────────────────────────────────────────
# Base URL of the docs app so the MCP can resolve per-customer Bearer tokens.
# Example (production): https://marmoui.com
# PLATFORM_API_URL=
