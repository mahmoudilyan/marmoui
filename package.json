{
  "name": "marmo-ui-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --filter=@marmoui/design-system-docs --filter=@marmoui/ui",
    "dev:all": "turbo dev",
    "dev:ui": "turbo dev --filter=@marmoui/ui",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "prepare": "husky",
    "generate:props": "pnpm --filter @marmoui/design-system-docs generate:props",
    "figma:node": "node scripts/figma-node.mjs",
    "changeset": "changeset",
    "changeset:status": "changeset status --since=origin/main",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "turbo build --filter=@marmoui/ui --filter=marmoui && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^8.56.0",
    "@types/node": "20.10.8",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "turbo": "^2.0.4",
    "typescript": "^5.3.3"
  },
  "pnpm": {
    "patchedDependencies": {}
  }
}
