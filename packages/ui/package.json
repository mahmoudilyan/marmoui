{
  "name": "@marmoui/ui",
  "version": "1.1.0",
  "description": "Marmo UI — a React 19 + Chakra-based component library for building dashboards fast.",
  "license": "MIT",
  "homepage": "https://marmoui.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/mahmoudilyan/marmoui.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/mahmoudilyan/marmoui/issues"
  },
  "keywords": [
    "react",
    "design-system",
    "components",
    "ui",
    "tailwind",
    "dashboard",
    "chakra",
    "marmo"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "source": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./style.css": "./dist/style.css",
    "./tokens.css": "./dist/tokens.css"
  },
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "node scripts/generate-css-from-tokens.mjs && rm -f dist/*.js dist/*.mjs && pnpm tailwindcss -i src/styles/globals.css -o dist/style.css --minify && cp src/styles/tokens.css dist/tokens.css && tsup",
    "generate:tokens": "node scripts/generate-css-from-tokens.mjs",
    "build:css": "tailwindcss -i src/styles/globals.css -o dist/style.css --minify",
    "tailwind": "tailwindcss -i src/styles/globals.css -o dist/style.css --minify",
    "dev": "tsup --watch --ignore-watch dist",
    "dev:js": "tsup --watch --ignore-watch dist",
    "dev:css": "tailwindcss -i src/styles/globals.css -o dist/style.css --watch",
    "prepublishOnly": "pnpm build",
    "lint": "eslint \"**/*.{ts,tsx}\"",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "peerDependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "dependencies": {
    "@diceui/tags-input": "^0.7.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/react": "^0.27.4",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.2",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "^4.1.0",
    "emoji-picker-react": "^4.12.2",
    "lucide-react": "^0.469.0",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.6.7",
    "react-hook-form": "^7.63.0",
    "react-icons": "^5.4.0",
    "recharts": "^2.15.3",
    "sonner": "^1.4.3",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@esbuild-plugins/tsconfig-paths": "^0.1.2",
    "@tailwindcss/cli": "^4.1.13",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^4.1.13",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  }
}
